						"body": {
							"mode": "raw",
							"raw": "{\n    \"amount\": 500,\n    \"type\": \"income\",\n    \"category\": \"Salary\",\n    \"paymentMethod\": \"Bank Transfer\",\n    \"date\": \"2026-04-05\",\n    \"notes\": \"Monthly salary\"\n}",
